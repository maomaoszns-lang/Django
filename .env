# 数据库配置 对应 settings.py 中的 DATABASES)
DB_NAME=devops
DB_USER=root
DB_PASSWORD=123456
#  docker-compose 中的服务名 'devdb'
DB_HOST=devdb
DB_PORT=3306

# Celery 配置 (对应 settings.py 中的 CELERY_BROKER_URL)
# docker-compose  'devredis'


CELERY_BROKER_URL=redis://devredis:6379/1
CELERY_RESULT_BACKEND=redis://devredis:6379/2

# 缓存配置 (对应 settings.py 中的 CACHES)
CACHE_URL=redis://devredis:6379/3
